!!!
%html
  %head
    :javascript
      (function(w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
        var f = d.getElementsByTagName(s)[0],
            j = d.createElement(s),
            dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-538FL33S');

    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title FujjimaBlog
    = csrf_meta_tags
    = csp_meta_tag

    -# ref) https://www.reddit.com/r/reactjs/comments/109cb1d/favicon_in_reactappvite/
    %link{ rel: "icon", type: "image/png", href: "/favicon.ico" }

    -# NOTE: Hot Module Reload 用タグ
    = vite_client_tag

    -# TODO: vite_stylesheet_tag のみ使えないので原因調査したい
    -# = vite_stylesheet_tag 'stylesheets/application.scss'
    = vite_javascript_tag 'application'
    = display_meta_tags(default_meta_tags)

    = analytics_init if Rails.env.production?
  = render 'layouts/header'
  %body
    %noscript
      %iframe{ src: "https://www.googletagmanager.com/ns.html?id=GTM-538FL33S", height: "0", width: "0", style: "display:none;visibility:hidden" }
    .wrapper
      .content-wrapper
        %main.container
          %div.row
            %div.col-md-8.blog-main
              = yield
            %aside.col-md-4.blog-sidebar
              = render 'layouts/sidebar'
