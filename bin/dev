#!/usr/bin/env sh

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# NOTE: Default to port 3000 if not specified
export PORT="${PORT:-3000}"

# NOTE: Let the debug gem allow remote connections,
# NOTE: but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

# NOTE: foremanをバックグラウンドで起動（Vite等）
foreman start -f Procfile.dev "$@" &
FOREMAN_PID=$!

# NOTE: シェルが終了するときに foreman を kill する設定
trap "kill $FOREMAN_PID" EXIT INT TERM

exec bin/rails server
